<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:padding="24dp">

    <!-- Trophy Image -->
    <ImageView
        android:id="@+id/iv_trophy"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="60dp"
        android:contentDescription="Trophy"
        android:src="@drawable/ic_trophy"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Match Completed Header -->
    <TextView
        android:id="@+id/tv_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="MATCH COMPLETED"
        android:textAppearance="@style/TextAppearance.CricScore.Label"
        android:textColor="@color/colorTextSecondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_trophy" />

    <!-- Winner Message -->
    <TextView
        android:id="@+id/tv_winner_message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textAppearance="@style/TextAppearance.CricScore.ScoreMedium"
        android:textColor="@color/colorPrimary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_header"
        tools:text="Pakistan won by 15 runs" />

    <TextView
        android:id="@+id/tv_match_teams"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textAppearance="@style/TextAppearance.CricScore.Caption"
        android:textColor="@color/colorTextSecondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_winner_message"
        tools:text="Pakistan vs India" />

    <!-- Summary Box Card -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_summary_box"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_card_surface"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/tv_match_teams">

        <TextView
            android:id="@+id/tv_innings1_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1st Innings"
            android:textAppearance="@style/TextAppearance.CricScore.Label"
            android:textColor="@color/colorTextSecondary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_innings1_summary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
            android:textColor="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_innings1_title"
            tools:text="Pakistan: 124 - 4 (5.0 Overs)" />

        <TextView
            android:id="@+id/tv_innings2_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="2nd Innings"
            android:textAppearance="@style/TextAppearance.CricScore.Label"
            android:textColor="@color/colorTextSecondary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_innings1_summary" />

        <TextView
            android:id="@+id/tv_innings2_summary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
            android:textColor="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_innings2_title"
            tools:text="India: 109 - 8 (5.0 Overs)" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CTAs -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_home"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/colorPrimary"
        android:text="Back to Home"
        android:textAppearance="@style/TextAppearance.CricScore.Button"
        android:textColor="@color/black"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toTopOf="@id/btn_view_scorecard" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_view_scorecard"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="View Detailed Scorecard"
        android:textAppearance="@style/TextAppearance.CricScore.Button"
        android:textColor="@color/white"
        app:strokeColor="@color/colorBorder"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
