<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:padding="16dp">

    <!-- Header -->
    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:src="@drawable/ic_back_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/tv_match_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textAppearance="@style/TextAppearance.CricScore.BodyLarge"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="@id/btn_back"
        app:layout_constraintEnd_toStartOf="@id/btn_view_scorecard"
        app:layout_constraintStart_toEndOf="@id/btn_back"
        app:layout_constraintTop_toTopOf="@id/btn_back"
        tools:text="Pakistan vs India" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_view_scorecard"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scorecard"
        android:textAppearance="@style/TextAppearance.CricScore.Label"
        android:textColor="@color/colorPrimary"
        app:layout_constraintBottom_toBottomOf="@id/btn_back"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btn_back" />

    <!-- Main Scorecard Card -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_scoreboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_card_surface"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/btn_back">

        <!-- Runs & Wickets -->
        <TextView
            android:id="@+id/tv_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.CricScore.ScoreLarge"
            android:textColor="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="148 - 3" />

        <!-- Overs -->
        <TextView
            android:id="@+id/tv_overs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textAppearance="@style/TextAppearance.CricScore.ScoreMedium"
            android:textColor="@color/colorTextSecondary"
            app:layout_constraintBottom_toBottomOf="@id/tv_score"
            app:layout_constraintStart_toEndOf="@id/tv_score"
            tools:text="14.2 Overs" />

        <!-- Run Rate info (Target & Needed runs) -->
        <TextView
            android:id="@+id/tv_rr_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="@style/TextAppearance.CricScore.Caption"
            android:textColor="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_score"
            tools:text="CRR: 10.42 · RRR: 8.50\nNeeds 42 runs off 30 balls" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Batsmen Table Container -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_batsmen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/colorSurface"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/cl_scoreboard">

        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:stretchColumns="0">

            <!-- Header Row -->
            <TableRow android:layout_marginBottom="8dp">
                <TextView
                    android:text="BATSMAN"
                    android:textAppearance="@style/TextAppearance.CricScore.Label"
                    android:textColor="@color/colorTextSecondary" />
                <TextView
                    android:text="R"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.Label"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_width="36dp" />
                <TextView
                    android:text="B"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.Label"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_width="36dp" />
                <TextView
                    android:text="4s"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.Label"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_width="36dp" />
                <TextView
                    android:text="6s"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.Label"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_width="36dp" />
                <TextView
                    android:text="SR"
                    android:gravity="end"
                    android:textAppearance="@style/TextAppearance.CricScore.Label"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_width="56dp" />
            </TableRow>

            <!-- Striker Row -->
            <TableRow
                android:id="@+id/tr_striker"
                android:layout_marginBottom="8dp">
                <TextView
                    android:id="@+id/tv_striker_name"
                    android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
                    android:textColor="@color/white"
                    tools:text="Striker *" />
                <TextView
                    android:id="@+id/tv_striker_runs"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
                    android:textColor="@color/white"
                    tools:text="45" />
                <TextView
                    android:id="@+id/tv_striker_balls"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
                    android:textColor="@color/colorTextSecondary"
                    tools:text="28" />
                <TextView
                    android:id="@+id/tv_striker_fours"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
                    android:textColor="@color/colorTextSecondary"
                    tools:text="4" />
                <TextView
                    android:id="@+id/tv_striker_sixes"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
                    android:textColor="@color/colorTextSecondary"
                    tools:text="2" />
                <TextView
                    android:id="@+id/tv_striker_sr"
                    android:gravity="end"
                    android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
                    android:textColor="@color/colorTextSecondary"
                    tools:text="160.7" />
            </TableRow>

            <!-- Non-Striker Row -->
            <TableRow android:id="@+id/tr_non_striker">
                <TextView
                    android:id="@+id/tv_non_striker_name"
                    android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
                    android:textColor="@color/white"
                    tools:text="Non-Striker" />
                <TextView
                    android:id="@+id/tv_non_striker_runs"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
                    android:textColor="@color/white"
                    tools:text="12" />
                <TextView
                    android:id="@+id/tv_non_striker_balls"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
                    android:textColor="@color/colorTextSecondary"
                    tools:text="10" />
                <TextView
                    android:id="@+id/tv_non_striker_fours"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
                    android:textColor="@color/colorTextSecondary"
                    tools:text="1" />
                <TextView
                    android:id="@+id/tv_non_striker_sixes"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
                    android:textColor="@color/colorTextSecondary"
                    tools:text="0" />
                <TextView
                    android:id="@+id/tv_non_striker_sr"
                    android:gravity="end"
                    android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
                    android:textColor="@color/colorTextSecondary"
                    tools:text="120.0" />
            </TableRow>
        </TableLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bowler Row Container -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_bowler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="@color/colorSurface"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/cv_batsmen">

        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:stretchColumns="0">

            <!-- Header Row -->
            <TableRow android:layout_marginBottom="8dp">
                <TextView
                    android:text="BOWLER"
                    android:textAppearance="@style/TextAppearance.CricScore.Label"
                    android:textColor="@color/colorTextSecondary" />
                <TextView
                    android:text="O"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.Label"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_width="36dp" />
                <TextView
                    android:text="M"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.Label"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_width="36dp" />
                <TextView
                    android:text="R"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.Label"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_width="36dp" />
                <TextView
                    android:text="W"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.Label"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_width="36dp" />
                <TextView
                    android:text="ECON"
                    android:gravity="end"
                    android:textAppearance="@style/TextAppearance.CricScore.Label"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_width="56dp" />
            </TableRow>

            <!-- Bowler Row -->
            <TableRow>
                <TextView
                    android:id="@+id/tv_bowler_name"
                    android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
                    android:textColor="@color/white"
                    tools:text="Bowler" />
                <TextView
                    android:id="@+id/tv_bowler_overs"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
                    android:textColor="@color/white"
                    tools:text="2.2" />
                <TextView
                    android:id="@+id/tv_bowler_maidens"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
                    android:textColor="@color/colorTextSecondary"
                    tools:text="0" />
                <TextView
                    android:id="@+id/tv_bowler_runs"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
                    android:textColor="@color/white"
                    tools:text="18" />
                <TextView
                    android:id="@+id/tv_bowler_wickets"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
                    android:textColor="@color/white"
                    tools:text="1" />
                <TextView
                    android:id="@+id/tv_bowler_econ"
                    android:gravity="end"
                    android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
                    android:textColor="@color/colorTextSecondary"
                    tools:text="7.71" />
            </TableRow>
        </TableLayout>
    </androidx.cardview.widget.CardView>

    <!-- Recent Deliveries (This Over) Ticker -->
    <TextView
        android:id="@+id/tv_this_over_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="THIS OVER"
        android:textAppearance="@style/TextAppearance.CricScore.Label"
        android:textColor="@color/colorTextSecondary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cv_bowler" />

    <HorizontalScrollView
        android:id="@+id/hsv_recent_balls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/tv_this_over_label">

        <LinearLayout
            android:id="@+id/ll_recent_balls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            tools:ignore="UselessLeaf" />

    </HorizontalScrollView>

    <!-- Score Input Controls Card -->
    <LinearLayout
        android:id="@+id/ll_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Runs Row (0, 1, 2, 3, 4, 6) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_runs_0"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="0"
                android:textColor="@color/white"
                app:strokeColor="@color/colorBorder"
                app:cornerRadius="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_runs_1"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:text="1"
                android:textColor="@color/white"
                app:strokeColor="@color/colorBorder"
                app:cornerRadius="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_runs_2"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:text="2"
                android:textColor="@color/white"
                app:strokeColor="@color/colorBorder"
                app:cornerRadius="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_runs_3"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:text="3"
                android:textColor="@color/white"
                app:strokeColor="@color/colorBorder"
                app:cornerRadius="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_runs_4"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:text="4"
                android:textColor="@color/black"
                app:backgroundTint="@color/colorFour"
                app:cornerRadius="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_runs_6"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="6"
                android:textColor="@color/black"
                app:backgroundTint="@color/colorSix"
                app:cornerRadius="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>

        <!-- Extras & Action Row (Wd, Nb, B, Lb, W, Undo) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_extra_wd"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1.2"
                android:layout_marginEnd="4dp"
                android:text="Wd"
                android:textColor="@color/white"
                app:strokeColor="@color/colorWide"
                app:cornerRadius="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_extra_nb"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1.2"
                android:layout_marginHorizontal="4dp"
                android:text="Nb"
                android:textColor="@color/white"
                app:strokeColor="@color/colorNoBall"
                app:cornerRadius="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_extra_bye"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:text="B"
                android:textColor="@color/white"
                app:strokeColor="@color/colorBorder"
                app:cornerRadius="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_extra_legbye"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:text="Lb"
                android:textColor="@color/white"
                app:strokeColor="@color/colorBorder"
                app:cornerRadius="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <!-- Wicket Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_wicket"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1.5"
                android:layout_marginHorizontal="4dp"
                android:text="W"
                android:textColor="@color/white"
                app:backgroundTint="@color/colorWicket"
                app:cornerRadius="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <!-- Undo Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_undo"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1.2"
                android:layout_marginStart="4dp"
                android:contentDescription="Undo"
                app:icon="@drawable/ic_undo"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@color/white"
                app:strokeColor="@color/colorBorder"
                app:cornerRadius="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
