<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/colorSurface"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WICKET DISMISSAL"
        android:textAppearance="@style/TextAppearance.CricScore.ScoreSmall"
        android:textColor="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Dismissal Type Dropdown / Spinner -->
    <TextView
        android:id="@+id/tv_dismissal_type_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Dismissal Type"
        android:textAppearance="@style/TextAppearance.CricScore.Label"
        android:textColor="@color/colorTextSecondary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <Spinner
        android:id="@+id/sp_dismissal_type"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_card_surface"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_dismissal_type_label" />

    <!-- Who was dismissed? -->
    <TextView
        android:id="@+id/tv_dismissed_player_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Who is out?"
        android:textAppearance="@style/TextAppearance.CricScore.Label"
        android:textColor="@color/colorTextSecondary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sp_dismissal_type" />

    <RadioGroup
        android:id="@+id/rg_dismissed_player"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tv_dismissed_player_label">

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/rb_striker"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:buttonTint="@color/colorPrimary"
            android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
            android:textColor="@color/white"
            tools:text="Striker Name" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/rb_non_striker"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:buttonTint="@color/colorPrimary"
            android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
            android:textColor="@color/white"
            tools:text="Non-Striker Name" />

    </RadioGroup>

    <!-- Fielder Name input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_fielder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Fielder Name (Optional)"
        android:textColorHint="@color/colorTextSecondary"
        app:boxStrokeColor="@color/colorPrimary"
        app:hintTextColor="@color/colorPrimary"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:layout_constraintTop_toBottomOf="@id/rg_dismissed_player">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_fielder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapWords"
            android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
            android:textColor="@color/white" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Next Batsman Name input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_next_batsman"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Next Batsman Name"
        android:textColorHint="@color/colorTextSecondary"
        app:boxStrokeColor="@color/colorPrimary"
        app:hintTextColor="@color/colorPrimary"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:layout_constraintTop_toBottomOf="@id/til_fielder">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_next_batsman"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapWords"
            android:textAppearance="@style/TextAppearance.CricScore.BodyMedium"
            android:textColor="@color/white" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Confirm Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_confirm_wicket"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/colorPrimary"
        android:text="Confirm Wicket"
        android:textAppearance="@style/TextAppearance.CricScore.Button"
        android:textColor="@color/black"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/til_next_batsman" />

</androidx.constraintlayout.widget.ConstraintLayout>
