<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Theme.CricScore" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorTertiary">@color/colorTertiary</item>
        <item name="colorError">@color/colorError</item>
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorSurfaceVariant">@color/colorSurfaceVariant</item>
        
        <!-- Status Bar & Navigation Bar Customization -->
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:navigationBarColor">@color/colorBackground</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o">false</item>
    </style>

    <!-- Typography TextAppearances -->
    <style name="TextAppearance.CricScore.ScoreLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:fontFamily">@font/barlow_condensed</item>
        <item name="android:textSize">72sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/colorOnBackground</item>
    </style>

    <style name="TextAppearance.CricScore.ScoreMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:fontFamily">@font/barlow_condensed</item>
        <item name="android:textSize">48sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/colorOnBackground</item>
    </style>

    <style name="TextAppearance.CricScore.ScoreSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">@font/barlow_condensed</item>
        <item name="android:fontFamily">@font/barlow_condensed</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/colorOnBackground</item>
    </style>

    <style name="TextAppearance.CricScore.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:textColor">@color/colorTextSecondary</item>
    </style>

    <style name="TextAppearance.CricScore.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/colorOnBackground</item>
    </style>

    <style name="TextAppearance.CricScore.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/colorOnBackground</item>
    </style>

    <style name="TextAppearance.CricScore.Button" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/colorOnBackground</item>
    </style>

    <style name="TextAppearance.CricScore.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/colorTextSecondary</item>
    </style>

    <style name="TextAppearance.CricScore.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">@font/dm_sans</item>
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/colorOnBackground</item>
    </style>
</resources>